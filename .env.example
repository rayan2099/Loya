NODE_ENV=development
PORT=3000

# Required in production. Use a long random value.
SESSION_SECRET=replace-with-at-least-32-random-characters

# Used only when a business is first created before the owner changes it in Settings.
DEFAULT_CASHIER_PIN=change-this-before-launch

# Public app URL used for generated QR links in deployed environments.
APP_URL=http://localhost:3000

# Supabase cutover variables. The current bundled server can run locally with JSON
# storage, but these are required when connecting the production database/auth layer.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
